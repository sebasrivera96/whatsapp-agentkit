# AgentKit — Variables de entorno
# Copia este archivo como .env y llena tus datos:
#   cp .env.example .env
#
# NUNCA subas el archivo .env a GitHub.

# ── Anthropic API ──────────────────────────────────────────
# Obtener en: https://platform.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=

# ── Proveedor de WhatsApp ──────────────────────────────────
# Opciones: whapi | meta | twilio
WHATSAPP_PROVIDER=whapi

# ── Whapi.cloud (si WHATSAPP_PROVIDER=whapi) ──────────────
# Obtener en: https://whapi.cloud (plan gratis disponible)
WHAPI_TOKEN=

# ── Meta Cloud API (si WHATSAPP_PROVIDER=meta) ────────────
# Configurar en: https://developers.facebook.com
# META_ACCESS_TOKEN=
# META_PHONE_NUMBER_ID=
# META_VERIFY_TOKEN=agentkit-verify

# ── Twilio (si WHATSAPP_PROVIDER=twilio) ──────────────────
# Configurar en: https://twilio.com
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# ── SICAS CRM ─────────────────────────────────────────────
# Credenciales del sistema SICAS Online (CRM de pólizas)
SICAS_API_URL=https://security-services.sicasonline.info/api
SICAS_USERNAME=
SICAS_PASSWORD=

# ── Escalación al asesor ───────────────────────────────────
# Número WhatsApp del asesor que recibe notificaciones (con código de país, sin +)
# Ej: 5218181234567
AGENT_WHATSAPP_NUMBER=

# ── URL pública del servidor ───────────────────────────────
# En desarrollo: http://localhost:8000
# En Railway: https://tu-app.up.railway.app  (copiar desde el dashboard)
PUBLIC_URL=http://localhost:8000

# ── Formularios PDF ───────────────────────────────────────
# Se auto-construyen como {PUBLIC_URL}/forms/solicitud_siniestros.pdf
# Solo sobreescribir si los formularios están en otro servidor.
# FORM_URL_REEMBOLSO=
# FORM_URL_PROCEDIMIENTO=

# ── Servidor ──────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development

# ── Base de datos ─────────────────────────────────────────
# Local (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./agentkit.db
# Produccion (PostgreSQL en Railway):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
